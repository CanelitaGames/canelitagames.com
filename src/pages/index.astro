---
import AdSenseUnit from "../components/AdSenseUnit.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import StoreBadge from "../components/StoreBadge.astro";
import { games } from "../data/games";
import { defaultLocale } from "../i18n/config";
import { buildMetaMap, homeContent } from "../i18n/content";
import "../styles/global.css";

const locale = defaultLocale;
const homeCopy = homeContent[locale];
const homeMeta = buildMetaMap(homeContent);

const structuredGames = games.map((game, index) => ({
	"@type": "SoftwareApplication",
	position: index + 1,
	name: game.title,
	applicationCategory: "GameApplication",
	operatingSystem: game.stores.ios ? "Android, iOS" : "Android",
	description: game.translations[locale].description,
	image: `https://canelitagames.com${game.logo}`,
	url: game.stores.android ?? game.stores.ios ?? "https://canelitagames.com/#juegos",
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
		availability: game.available
			? "https://schema.org/InStock"
			: "https://schema.org/PreOrder",
	},
}));

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		name: "Canelita Games",
		url: "https://canelitagames.com",
		logo: "https://canelitagames.com/logos/canelita-games-current.png",
		sameAs: [
			"https://play.google.com/store/apps/dev?id=6148040112617060945&hl=es_419",
		],
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "Canelita Games",
		url: "https://canelitagames.com",
		description: homeCopy.structuredData.websiteDescription,
	},
	{
		"@context": "https://schema.org",
		"@type": "ItemList",
		name: homeCopy.structuredData.itemListName,
		itemListElement: structuredGames,
	},
];

const homeRuntime = {
	defaultLocale,
	homeContent,
	games,
};
---

<BaseLayout
	title={homeCopy.meta.title}
	description={homeCopy.meta.description}
	ogImage="/logos/canelita-games-current.png"
	structuredData={structuredData}
	localizedMeta={homeMeta}
>
	<div class="page-shell">
		<div class="noise"></div>

		<header class="catalog-header">
			<div class="container catalog-header-inner">
				<div class="intro-copy">
					<span class="hero-badge" data-home-badge>{homeCopy.hero.badge}</span>
					<h1 class="brand-title">
						<span>CANELITA</span>
						<span>GAMES</span>
					</h1>
					<p data-home-description>{homeCopy.hero.description}</p>
				</div>
				<div class="intro-actions">
					<a class="button button-primary" href="#juegos" data-home-primary-cta>{homeCopy.hero.primaryCta}</a>
					<a class="button button-secondary" href="https://play.google.com/store/apps/dev?id=6148040112617060945&hl=es_419" target="_blank" rel="noreferrer" data-home-secondary-cta>{homeCopy.hero.secondaryCta}</a>
				</div>
			</div>
		</header>

		<main>
			<AdSenseUnit slot={import.meta.env.PUBLIC_GOOGLE_ADSENSE_SLOT_HOME_TOP} className="container top-ad" />

			<section class="section" id="juegos">
				<div class="container">
					<div class="section-heading">
						<span class="section-kicker" data-home-section-kicker>{homeCopy.section.kicker}</span>
						<h2 data-home-section-title>{homeCopy.section.title}</h2>
						<p data-home-section-description>{homeCopy.section.description}</p>
					</div>

					<div class="catalog-grid">
						{
							games.map((game) => (
								<article class="catalog-card" data-accent={game.accent} data-game-id={game.id}>
									<div class="catalog-card-media">
										<img src={game.logo} alt={`Logo de ${game.title}`} loading="lazy" />
									</div>
									<div class="catalog-card-body">
										<div class="game-header">
											<span class="pill" data-game-status>{game.translations[locale].status}</span>
										</div>
										<h3>{game.title}</h3>
										<p class="game-tagline" data-game-tagline>{game.translations[locale].tagline}</p>
										<p data-game-description>{game.translations[locale].description}</p>
										<ul class="game-highlights" aria-label={`${homeCopy.labels.highlightsAria} ${game.title}`} data-game-highlights>
											{game.translations[locale].highlights.map((item) => <li>{item}</li>)}
										</ul>
										<div class="store-links">
											<div data-store-android>
												<StoreBadge
													platform="android"
													label={game.stores.android ? "Google Play" : homeCopy.labels.googlePlaySoon}
													href={game.stores.android}
													disabled={!game.stores.android}
												/>
											</div>
											<div data-store-ios>
												<StoreBadge
													platform="ios"
													label={game.stores.ios ? "App Store" : homeCopy.labels.appStoreSoon}
													href={game.stores.ios}
													disabled={!game.stores.ios}
												/>
											</div>
										</div>
									</div>
								</article>
							))
						}
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</div>
	<script type="application/json" id="home-i18n" set:html={JSON.stringify(homeRuntime)}></script>
	<script is:inline>
		(() => {
			const payload = document.getElementById("home-i18n");

			if (!payload?.textContent) {
				return;
			}

			const runtime = JSON.parse(payload.textContent);

			const render = (locale) => {
				const copy = runtime.homeContent[locale] ?? runtime.homeContent[runtime.defaultLocale];
				const badge = document.querySelector("[data-home-badge]");
				const description = document.querySelector("[data-home-description]");
				const primaryCta = document.querySelector("[data-home-primary-cta]");
				const secondaryCta = document.querySelector("[data-home-secondary-cta]");
				const sectionKicker = document.querySelector("[data-home-section-kicker]");
				const sectionTitle = document.querySelector("[data-home-section-title]");
				const sectionDescription = document.querySelector("[data-home-section-description]");

				if (badge) badge.textContent = copy.hero.badge;
				if (description) description.textContent = copy.hero.description;
				if (primaryCta) primaryCta.textContent = copy.hero.primaryCta;
				if (secondaryCta) secondaryCta.textContent = copy.hero.secondaryCta;
				if (sectionKicker) sectionKicker.textContent = copy.section.kicker;
				if (sectionTitle) sectionTitle.textContent = copy.section.title;
				if (sectionDescription) sectionDescription.textContent = copy.section.description;

				document.querySelectorAll("[data-game-id]").forEach((card) => {
					const gameId = card.getAttribute("data-game-id");
					const game = runtime.games.find((entry) => entry.id === gameId);

					if (!game) {
						return;
					}

					const gameCopy = game.translations[locale] ?? game.translations[runtime.defaultLocale];
					const status = card.querySelector("[data-game-status]");
					const tagline = card.querySelector("[data-game-tagline]");
					const descriptionNode = card.querySelector("[data-game-description]");
					const highlights = card.querySelector("[data-game-highlights]");
					const androidLabel = card.querySelector("[data-store-android] [data-store-label]");
					const iosLabel = card.querySelector("[data-store-ios] [data-store-label]");

					if (status) status.textContent = gameCopy.status;
					if (tagline) tagline.textContent = gameCopy.tagline;
					if (descriptionNode) descriptionNode.textContent = gameCopy.description;
					if (highlights) {
						highlights.setAttribute("aria-label", `${copy.labels.highlightsAria} ${game.title}`);
						highlights.innerHTML = gameCopy.highlights.map((item) => `<li>${item}</li>`).join("");
					}
					if (androidLabel) androidLabel.textContent = game.stores.android ? "Google Play" : copy.labels.googlePlaySoon;
					if (iosLabel) iosLabel.textContent = game.stores.ios ? "App Store" : copy.labels.appStoreSoon;
				});
			};

			window.addEventListener("canelita:localechange", (event) => render(event.detail.locale));
			render(document.documentElement.dataset.locale ?? runtime.defaultLocale);
		})();
	</script>
</BaseLayout>


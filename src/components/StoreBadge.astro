---
interface Props {
	href?: string;
	platform: "android" | "ios";
	label: string;
	disabled?: boolean;
}

const { href, platform, label, disabled = false } = Astro.props;
---

{
	disabled ? (
		<span class="store-badge store-badge-disabled" aria-disabled="true" data-store-badge data-store-platform={platform}>
			{platform === "android" ? (
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M17.6 9.48l1.74-3.01a.75.75 0 10-1.3-.75l-1.77 3.06A10.5 10.5 0 0012 7.9c-1.52 0-2.98.31-4.27.88L5.96 5.72a.75.75 0 00-1.3.75L6.4 9.48A8.6 8.6 0 003 16h18a8.6 8.6 0 00-3.4-6.52ZM8.5 13.25a1 1 0 110-2 1 1 0 010 2Zm7 0a1 1 0 110-2 1 1 0 010 2Z" fill="currentColor"/>
					<path d="M7 17.5v2a1.5 1.5 0 103 0v-2H7Zm7 0v2a1.5 1.5 0 103 0v-2h-3Z" fill="currentColor"/>
				</svg>
			) : (
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M16.37 12.8c.02 2.24 1.96 2.99 1.98 3-.02.05-.31 1.07-1.03 2.11-.62.89-1.27 1.78-2.28 1.8-1 .02-1.32-.6-2.46-.6-1.15 0-1.51.58-2.43.62-.98.04-1.73-.98-2.36-1.87-1.28-1.85-2.26-5.23-.95-7.5.65-1.13 1.82-1.84 3.09-1.86.96-.02 1.86.64 2.45.64.59 0 1.7-.79 2.86-.67.49.02 1.88.2 2.77 1.5-.07.05-1.65.96-1.64 2.83Z" fill="currentColor"/>
					<path d="M14.83 6.14c.52-.63.87-1.5.77-2.37-.75.03-1.66.5-2.2 1.13-.48.56-.9 1.45-.78 2.3.84.06 1.69-.43 2.21-1.06Z" fill="currentColor"/>
				</svg>
			)}
			<span data-store-label>{label}</span>
		</span>
	) : (
		<a class="store-badge" href={href} target="_blank" rel="noreferrer" data-store-badge data-store-platform={platform}>
			{platform === "android" ? (
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M17.6 9.48l1.74-3.01a.75.75 0 10-1.3-.75l-1.77 3.06A10.5 10.5 0 0012 7.9c-1.52 0-2.98.31-4.27.88L5.96 5.72a.75.75 0 00-1.3.75L6.4 9.48A8.6 8.6 0 003 16h18a8.6 8.6 0 00-3.4-6.52ZM8.5 13.25a1 1 0 110-2 1 1 0 010 2Zm7 0a1 1 0 110-2 1 1 0 010 2Z" fill="currentColor"/>
					<path d="M7 17.5v2a1.5 1.5 0 103 0v-2H7Zm7 0v2a1.5 1.5 0 103 0v-2h-3Z" fill="currentColor"/>
				</svg>
			) : (
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M16.37 12.8c.02 2.24 1.96 2.99 1.98 3-.02.05-.31 1.07-1.03 2.11-.62.89-1.27 1.78-2.28 1.8-1 .02-1.32-.6-2.46-.6-1.15 0-1.51.58-2.43.62-.98.04-1.73-.98-2.36-1.87-1.28-1.85-2.26-5.23-.95-7.5.65-1.13 1.82-1.84 3.09-1.86.96-.02 1.86.64 2.45.64.59 0 1.7-.79 2.86-.67.49.02 1.88.2 2.77 1.5-.07.05-1.65.96-1.64 2.83Z" fill="currentColor"/>
					<path d="M14.83 6.14c.52-.63.87-1.5.77-2.37-.75.03-1.66.5-2.2 1.13-.48.56-.9 1.45-.78 2.3.84.06 1.69-.43 2.21-1.06Z" fill="currentColor"/>
				</svg>
			)}
			<span data-store-label>{label}</span>
		</a>
	)
}

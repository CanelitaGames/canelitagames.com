---
interface Props {
	slot?: string;
	className?: string;
	format?: "auto" | "fluid" | "rectangle" | "horizontal" | "vertical";
	responsive?: boolean;
}

const {
	slot,
	className = "adsense-unit",
	format = "auto",
	responsive = true,
} = Astro.props;

const client = import.meta.env.PUBLIC_GOOGLE_ADSENSE_CLIENT;
const shouldRender = Boolean(client && slot);
---

{
	shouldRender && (
		<div class={className} aria-label="Publicidad">
			<ins
				class="adsbygoogle"
				style="display:block"
				data-ad-client={client}
				data-ad-slot={slot}
				data-ad-format={format}
				data-full-width-responsive={responsive ? "true" : "false"}
			></ins>
			<script is:inline>
				(adsbygoogle = window.adsbygoogle || []).push({});
			</script>
		</div>
	)
}
